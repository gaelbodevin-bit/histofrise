rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Scores utilisateurs ──────────────────────────────
    // Lecture publique (classement visible par tous)
    // Écriture uniquement par le propriétaire du document
    match /scores/{userId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'displayName', 'totalPoints'])
                    && request.resource.data.totalPoints is number;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    // Empêche de diminuer le score (anti-triche basique)
                    && request.resource.data.totalPoints >= resource.data.totalPoints - 10000;
      allow delete: if false;
    }

    // ── Rooms multijoueur ────────────────────────────────
    // Joueurs authentifiés uniquement
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.host == request.auth.uid;
      allow update: if request.auth != null
                    && (
                      // Hôte peut tout modifier
                      resource.data.host == request.auth.uid
                      // Joueur peut modifier son propre profil dans players
                      || request.auth.uid in resource.data.players
                    );
      allow delete: if request.auth != null
                    && resource.data.host == request.auth.uid;
    }
  }
}
